# Evavo Quotation Platform — PRODUCTION env for DigitalOcean (PostgreSQL).
# Copy this to backend/.env.production and fill in real values. Keep it readable only by
# the service account (it contains the DB password and JWT secret).

# --- DigitalOcean Managed PostgreSQL ---
# Get the connection string from your DigitalOcean database cluster page.
# Format: postgresql://dbaas_user:PASSWORD@host.region.mdb.digitalocean.com:25060/evavo
# Simply set DATABASE_URL directly (simplest approach):
EVAVO_DATABASE_URL=postgresql://dbaas_user:CHANGE_ME_PASSWORD@host.region.mdb.digitalocean.com:25060/evavo

# Or use individual PostgreSQL settings (if preferred):
# EVAVO_PG_HOST=host.region.mdb.digitalocean.com
# EVAVO_PG_PORT=25060
# EVAVO_PG_NAME=evavo
# EVAVO_PG_USER=dbaas_user
# EVAVO_PG_PASSWORD=CHANGE_ME_PASSWORD

# --- Auth ---
# Generate a strong secret, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
EVAVO_JWT_SECRET=CHANGE_ME_generate_a_long_random_secret
EVAVO_JWT_EXPIRE_MINUTES=720

# --- Web ---
# Your DigitalOcean Droplet domain (after DNS setup)
EVAVO_CORS_ORIGINS=quotation.evavo.in,localhost

# --- Excel masters (for: python manage.py import-excel) ---
# Absolute path to the folder containing the client .xlsx working sheets.
# On DigitalOcean Droplet, this is typically /opt/evavo-quotation/working\ excel\ sheet\ from\ clients
EVAVO_SHEETS_DIR=/opt/evavo-quotation/working\ excel\ sheet\ from\ clients

# --- Optional: Debug mode (set to false in production) ---
EVAVO_DB_ECHO=false
