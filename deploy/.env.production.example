# Evavo Quotation Platform — PRODUCTION env for Windows Server.
# Copy this to  backend\.env  and fill in real values. Keep it readable only by
# the service account (it contains the DB password and JWT secret).

# --- SQL Server (existing instance, SQL login auth) ---
# If using a named instance, set host to the machine and instance via port, e.g.
# find the instance's TCP port in SQL Server Configuration Manager and use it.
EVAVO_DB_HOST=localhost
EVAVO_DB_PORT=1433
EVAVO_DB_NAME=evavo
EVAVO_DB_USER=evavo_app
EVAVO_DB_PASSWORD=CHANGE_ME_strong_password
EVAVO_DB_DRIVER=ODBC Driver 18 for SQL Server
EVAVO_DB_TRUST_CERT=true
EVAVO_DB_ECHO=false

# --- Auth ---
# Generate a strong secret, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
EVAVO_JWT_SECRET=CHANGE_ME_generate_a_long_random_secret
EVAVO_JWT_EXPIRE_MINUTES=720

# --- Web ---
# SPA is served same-origin, so "*" is acceptable on an internal LAN. Restrict if
# the API is reachable from outside, e.g. EVAVO_CORS_ORIGINS=http://evavo.local:8000
EVAVO_CORS_ORIGINS=*

# --- Excel masters (for: python manage.py import-excel) ---
# Absolute path to the folder containing the client .xlsx working sheets.
EVAVO_SHEETS_DIR=C:\Evavo\working excel sheet from clients
