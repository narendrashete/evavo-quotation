# Copy to backend/.env for local runs (outside Docker). All vars are EVAVO_-prefixed.

# --- Database ---
# Option 1: MSSQL (via pyodbc) — set db_* vars
EVAVO_DB_HOST=localhost
EVAVO_DB_PORT=1433
EVAVO_DB_NAME=evavo
EVAVO_DB_USER=sa
EVAVO_DB_PASSWORD=Your_strong_Pass123
EVAVO_DB_DRIVER=ODBC Driver 18 for SQL Server
EVAVO_DB_TRUST_CERT=true
EVAVO_DB_ECHO=false

# Option 2: PostgreSQL (via psycopg2) — set pg_* vars or use DATABASE_URL
# EVAVO_PG_HOST=localhost
# EVAVO_PG_PORT=5432
# EVAVO_PG_NAME=evavo
# EVAVO_PG_USER=postgres
# EVAVO_PG_PASSWORD=postgres_password

# Option 3: Direct connection string (takes precedence over db_*/pg_* vars)
# EVAVO_DATABASE_URL=postgresql://user:password@host:5432/evavo
# EVAVO_DATABASE_URL=mssql+pyodbc:///?odbc_connect=...

# --- Auth ---
EVAVO_JWT_SECRET=change-me-in-production
EVAVO_JWT_EXPIRE_MINUTES=720

# --- Optional: path to the client Excel workbooks for /api/import & /api/parity ---
# Leave blank to use the default ../../../working excel sheet from clients
EVAVO_SHEETS_DIR=

# --- Optional: public base URL used to build quote share links for the
# WhatsApp/email "Send" actions (e.g. https://quotation.evavo.in). Leave blank
# to fall back to the incoming request's own host — only set this to force a
# specific domain/scheme (e.g. if the app sits behind a proxy that doesn't
# forward the original host/scheme correctly).
EVAVO_APP_PUBLIC_URL=

# Gmail sending itself is NOT configured here — it's set up in-app under
# Masters > Email Setup (SMTP host smtp.gmail.com, port 587, your Gmail
# address as username, and a Google Account App Password — not your normal
# Gmail password — as the password). See README for setup steps.
